{
  "$schema": "https://raw.githubusercontent.com/LGUG2Z/komorebi/v0.1.40/schema.json",
  "app_specific_configuration_path": "$Env:USERPROFILE/applications.json",
  "window_container_behaviour": "Create",
  "window_hiding_behaviour": "Cloak",
  "unmanaged_window_operation_behaviour": "Op",
  "mouse_follows_focus": false,
  "float_override": false,
  "animation": {
    "enabled":true,
    "duration": 250,
    "fps": 60,
    "style": "EaseInOutSine"
  },
  "transparency": false,
  "transparency_alpha": 225,
  "cross_monitor_move_behaviour": "Insert",
  "default_workspace_padding": 5,
  "default_container_padding": 5,
  "border": false,
  "border_width": 2,
  "border_offset": -1,
  "theme": {
    "palette": "Base16",
    "name": "Ashes",
    "unfocused_border": "Base03",
    "bar_accent": "Base0D"
  },
  "stackbar": {
    "height": 25,
    "mode": "OnStack",
    "tabs": {
      "width": 300
    }
  },
  "monitors": [
    {
      "workspaces": [
        {
          "name": "I",
          "layout": "BSP"
        },
        {
          "name": "II",
          "layout": "VerticalStack"
        },
        {
          "name": "III",
          "layout": "HorizontalStack"
        },
        {
          "name": "IV",
          "layout": "UltrawideVerticalStack"
        },
        {
          "name": "V",
          "layout": "Rows"
        },
        {
          "name": "VI",
          "layout": "Grid"
        },
        {
          "name": "VII",
          "layout": "RightMainVerticalStack"
        },
        {
          "name": "VIII",
          "layout": "Columns"
        }
      ]
    }
  ],
  "ignore_rules": [
    {
      "kind": "Exe",
      "matching_strategy": "Equals",
      "id": "Discord.exe"
    },
    {
      "kind": "Exe",
      "matching_strategy": "Equals",
      "id": "steamwebhelper.exe"
    },
    {
      "kind": "Exe",
      "matching_strategy": "Equals",
      "id": "EpicGamesLauncher.exe"
    },
    {
      "kind": "Title",
      "id": "Calculadora"
    },
    {
      "kind": "Exe",
      "id": "WinRAR.exe"
    },
    {
      "kind": "Title",
      "matching_strategy": "Contains",
      "id": "WHKD Keybinds"
    },
    {
      "kind": "Title",
      "matching_strategy": "Contains",
      "id": "Picture-in-picture"
    },
    {
      "kind": "Exe",
      "id": "qbittorrent.exe"
    },
    {
      "kind": "Exe",
      "id": "Hayase.exe"
    },
    {
      "kind": "Exe",
      "id": "stremio-shell-ng.exe"
    },
    {
      "kind": "Exe",
      "id": "fdm.exe"
    },
    {
      "kind": "Exe",
      "id": "pot.exe"
    },
    {
      "kind": "Exe",
      "id": "obs64.exe"
    },
    {
